# ============================================================
# ENVIRONMENT VARIABLES — Teacher Recruitment System
# ============================================================
# HOW TO USE THIS FILE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in the values below with your actual credentials
# 3. NEVER commit the .env file (it's in .gitignore)
#
# WHY: Secrets (passwords, API keys) should never be in code.
#       They go in environment variables which are loaded at runtime.
# ============================================================

# --- Server Configuration ---
# PORT: Which port the server listens on. 5000 is common for backends.
# NODE_ENV: "development" enables detailed error messages. "production" hides them.
PORT=5000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# FORMAT: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# This tells Prisma ORM how to connect to your PostgreSQL database.
# For local development, you'd typically create a database called "teacher_recruitment_dev"
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/teacher_recruitment_dev"

# --- Redis ---
# Redis is an in-memory database used for:
# - Storing OTPs (temporary codes sent to phone/email)
# - Rate limiting (preventing too many requests)
# - Caching (storing frequently accessed data for speed)
# - Job queues (background tasks like auto-release)
REDIS_URL="redis://localhost:6379"

# --- JWT (JSON Web Tokens) ---
# These are secret keys used to sign tokens. Tokens prove "this user is logged in."
# ACCESS_TOKEN: Short-lived (15 min), used for every API request
# REFRESH_TOKEN: Long-lived (7 days), used to get a new access token when it expires
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace_with_a_long_random_string_for_access_tokens"
JWT_REFRESH_SECRET="replace_with_a_different_long_random_string_for_refresh_tokens"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# --- OTP Service (MSG91 — Indian SMS provider) ---
# MSG91 sends SMS messages for OTP verification
# Sign up at https://msg91.com to get these values
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_TEMPLATE_ID="your_msg91_template_id"
MSG91_SENDER_ID="TCHREC"

# --- Email Service (SendGrid) ---
# SendGrid sends emails (verification, notifications, interview invites)
# Sign up at https://sendgrid.com to get an API key
SENDGRID_API_KEY="your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="noreply@yourplatform.com"
SENDGRID_FROM_NAME="Teacher Recruitment System"

# --- Payment Gateway (Razorpay) ---
# Razorpay processes payments for school registration fees
# Sign up at https://razorpay.com to get test keys
# Use "test" keys during development (no real money charged)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# --- AWS S3 (File Storage) ---
# S3 stores uploaded files (chat attachments, documents)
# Region ap-south-1 = Mumbai, India (for data localization)
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="teacher-recruitment-files-dev"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"

# --- Frontend URL ---
# Used for CORS (allowing the frontend to talk to the backend)
# and for generating links in emails
FRONTEND_URL="http://localhost:3000"

# --- Admin Account (Pre-seeded) ---
# The admin account is created during database seeding
# There's no self-registration for admins — this is the only way
ADMIN_EMAIL="admin@yourplatform.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_PHONE="+919999999999"

# --- Free School Limit ---
# First 200 schools register for free. After that, they pay.
# This counter is tracked in Redis for atomic (thread-safe) operations.
FREE_SCHOOL_LIMIT=200

# --- Registration Fee (in paisa — Razorpay uses smallest currency unit) ---
# 5000 INR = 500000 paisa
REGISTRATION_FEE=500000

# --- ML Microservice (Python FastAPI) ---
# Separate Python server that handles AI matching + Profile Coach
# Start it: cd ml-service && uvicorn main:app --port 8000
# If not running, the system falls back to local rule-based matching
ML_SERVICE_URL="http://localhost:8000"
ML_API_KEY="dev-ml-api-key-change-me"
